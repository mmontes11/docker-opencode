{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^Dockerfile$/',
      ],
      matchStrings: [
        'OPENCODE_VERSION=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)',
      ],
      datasourceTemplate: 'github-releases',
      depNameTemplate: 'anomalyco/opencode',
      packageNameTemplate: 'anomalyco/opencode',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^Dockerfile$/',
      ],
      matchStrings: [
        'K8S_TOOLING_VERSION=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)',
      ],
      datasourceTemplate: 'github-releases',
      depNameTemplate: 'mmontes11/k8s-tooling',
      packageNameTemplate: 'mmontes11/k8s-tooling',
    },
  ],
  packageRules: [
    {
      matchManagers: [
        'github-actions',
      ],
      automerge: true,
      ignoreTests: true,
    },
    {
      matchDatasources: [
        'github-releases',
      ],
      matchPackageNames: [
        'anomalyco/opencode',
        'mmontes11/k8s-tooling',
      ],
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      automerge: true,
    },
  ],
}
