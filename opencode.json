{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "llama-qwen35-35b-3q/llama-qwen35-35b-3q",
  "small_model": "gpt-oss:20b-ctx128k",
  "permission": {
    "bash": {
      "*": "ask",
      "grep": "allow",
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "deny",
      "rm *": "deny",
      ":(){:|:&};:": "deny"
    },
    "edit": "ask",
    "write": "ask",
    "read": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "agent": {
    "kubernetes": {
      "model": "llama-qwen35-35b-3q/llama-qwen35-35b-3q",
      "temperature": 0.1,
      "description": "Expert SRE focused on diagnosing complex Kubernetes issues: compute, storage, databases, and infrastructure failures.",
      "prompt": "You are a Senior Kubernetes Site Reliability Engineer (SRE). Your expertise lies in the intersection Kubernetes infrastructure and stateful workloads (databases). When troubleshooting, perform a root-cause analysis and make suggestions to resolve the problem.",
      "permission": {
        "write": "deny",
        "edit": "deny"
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://ollama:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b",
          "limit": {
            "context": 32768,
            "output": 65536
          }
        },
        "gpt-oss:20b-ctx128k": {
          "name": "gpt-oss:20b-ctx128k",
          "limit": {
            "context": 131072,
            "output": 65536
          }
        }
      }
    },
    "llama-qwen35-35b": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp",
      "options": {
        "baseURL": "http://llama-qwen35-35b:8080/v1"
      },
      "models": {
        "qwen35-35b": {
          "name": "qwen35-35b",
          "limit": {
            "context": 49152,
            "output": 65536
          }
        }
      }
    },
    "llama-qwen35-35b-3q": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp",
      "options": {
        "baseURL": "http://llama-qwen35-35b-q3:8080/v1"
      },
      "models": {
        "qwen35-35b-3q": {
          "name": "qwen35-35b-3q",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "mcp": {
    "kubernetes": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-kubernetes:8080/mcp"
    },
    "grafana": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-grafana:8000/mcp"
    },
    "photprism-mmontes": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-photoprism-mmontes:9001/mcp"
    },
    "photprism-xiaowen": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-photoprism-xiaowen:9001/mcp"
    },
	  "github": {
      "enabled": true,
     	"type": "remote",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}",
        "X-MCP-Readonly": "true"
      }
    }
  }
}